{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-remote-dev",
  "description": "IPC for Vite dev server on mobile (Tauri 2 remote URL ACL).",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "remote": {
    "urls": [
      "http://*:5173/*",
      "https://*:5173/*"
    ]
  },
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:allow-open-url"
  ]
}
