{
  "name": "memory-pak",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "setup": "rustup target add wasm32-unknown-unknown && cargo install wasm-pack --version 0.14.0 --locked && cargo install tauri-cli --version 2.11.1 --locked && bun install --cwd frontend --frozen-lockfile",
    "install-tools": "bun run setup",

    "fmt": "cargo fmt --all",
    "fmt:check": "cargo fmt --all -- --check",
    "clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "test": "cargo test --workspace",
    "check": "cargo check --workspace",
    "check:wasm": "cargo check -p memory_pak_wasm --target wasm32-unknown-unknown",
    "check:desktop": "cargo tauri build --no-bundle --ci",
    "check:fast": "bun run fmt:check && bun run clippy && bun run test && bun run check:wasm && bun run frontend:test && bun run frontend:check && bun run frontend:build",
    "check:ci": "bun run check:fast && bun run frontend:e2e && bun run check:desktop",

    "dev:web": "bun run --cwd frontend dev",
    "dev:desktop": "cargo tauri dev",
    "dev:android": "cargo tauri android dev",
    "frontend:dev": "bun run dev:web",
    "frontend:dev:tauri": "bun run --cwd frontend dev:tauri",
    "build:web": "bun run --cwd frontend build",
    "build:desktop": "cargo tauri build --no-bundle --ci",
    "build:android": "cargo tauri android build",
    "package:desktop": "cargo tauri build",
    "frontend:build": "bun run build:web",
    "frontend:test": "bun run --cwd frontend test",
    "frontend:e2e": "bun run --cwd frontend e2e",
    "frontend:check": "bun run --cwd frontend check",

    "tauri:dev": "bun run dev:desktop",
    "tauri:build": "bun run package:desktop",
    "tauri:build:win": "cargo tauri build --bundles nsis,msi",
    "tauri:build:mac": "cargo tauri build --bundles dmg",
    "tauri:build:linux": "cargo tauri build --bundles appimage,deb",

    "android:init": "cargo tauri android init",
    "android:dev": "cargo tauri android dev",
    "android:build": "cargo tauri android build",
    "ios:init": "cargo tauri ios init",
    "ios:dev": "cargo tauri ios dev",
    "ios:build": "cargo tauri ios build",

    "all-checks": "bun run check:fast"
  }
}
