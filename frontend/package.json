{
  "name": "memory-pak-frontend",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run wasm:build && vite",
    "dev:tauri": "bun run wasm:build && vite --host 0.0.0.0",
    "dev:e2e": "bun run wasm:build && vite --host 127.0.0.1",
    "build": "bun run wasm:build && svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "wasm:build": "wasm-pack build ../crates/memory_pak_wasm --target web --out-dir ../../frontend/src/wasm --out-name memory_pak_wasm"
  },
  "dependencies": {
    "@tanstack/svelte-virtual": "^3.13.13",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "lucide-svelte": "^0.468.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
